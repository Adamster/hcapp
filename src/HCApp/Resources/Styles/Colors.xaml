<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================================
         SEMANTIC STATUS COLORS (unchanged)
    ============================================================ -->
    <Color x:Key="StatusHealthy">#2DB87A</Color>
    <Color x:Key="StatusHealthyDim">#1A6845</Color>
    <Color x:Key="StatusHealthySubtle">#0D2E1E</Color>
    <Color x:Key="StatusHealthySubtleLight">#E6F7F1</Color>

    <Color x:Key="StatusDegraded">#E8963A</Color>
    <Color x:Key="StatusDegradedDim">#9A5A15</Color>
    <Color x:Key="StatusDegradedSubtle">#2E1A08</Color>
    <Color x:Key="StatusDegradedSubtleLight">#FEF3E6</Color>

    <Color x:Key="StatusUnhealthy">#E0443A</Color>
    <Color x:Key="StatusUnhealthyDim">#9A2020</Color>
    <Color x:Key="StatusUnhealthySubtle">#2E0F0F</Color>
    <Color x:Key="StatusUnhealthySubtleLight">#FCE8E7</Color>

    <Color x:Key="StatusUnknown">#6C757D</Color>
    <Color x:Key="StatusUnknownSubtle">#1E2125</Color>
    <Color x:Key="StatusUnknownSubtleLight">#F1F3F5</Color>

    <!-- ============================================================
         BRAND — warm brass / amber gold
    ============================================================ -->
    <Color x:Key="BrandPrimary">#C89020</Color>
    <Color x:Key="BrandPrimaryHover">#A87010</Color>
    <Color x:Key="BrandPrimarySubtle">#2A1E08</Color>
    <Color x:Key="BrandPrimarySubtleLight">#FDF0D0</Color>

    <!-- ============================================================
         SURFACES — dark theme (oiled iron + aged wood interior)
    ============================================================ -->
    <Color x:Key="SurfaceDark">#110E09</Color>
    <Color x:Key="SurfaceSecondaryDark">#1A1510</Color>
    <Color x:Key="SurfaceTertiaryDark">#22190F</Color>
    <Color x:Key="SurfaceElevatedDark">#2A2015</Color>
    <Color x:Key="SurfaceBorderDark">#4A3C28</Color>
    <Color x:Key="SurfaceBorderStrongDark">#7A6240</Color>

    <!-- ============================================================
         SURFACES — light theme (aged parchment)
    ============================================================ -->
    <Color x:Key="SurfaceLight">#F5EDD8</Color>
    <Color x:Key="SurfaceSecondaryLight">#EDE0C4</Color>
    <Color x:Key="SurfaceTertiaryLight">#E3D4B0</Color>
    <Color x:Key="SurfaceElevatedLight">#F8F2E4</Color>
    <Color x:Key="SurfaceBorderLight">#C4A96A</Color>
    <Color x:Key="SurfaceBorderStrongLight">#A07840</Color>

    <!-- ============================================================
         ON-SURFACE TEXT — dark theme
    ============================================================ -->
    <Color x:Key="TextPrimaryDark">#E8D5A0</Color>
    <Color x:Key="TextSecondaryDark">#A09070</Color>
    <Color x:Key="TextTertiaryDark">#6B5A3A</Color>
    <Color x:Key="TextDisabledDark">#3A3020</Color>

    <!-- ============================================================
         ON-SURFACE TEXT — light theme
    ============================================================ -->
    <Color x:Key="TextPrimaryLight">#2A1E08</Color>
    <Color x:Key="TextSecondaryLight">#5A4020</Color>
    <Color x:Key="TextTertiaryLight">#8A6840</Color>
    <Color x:Key="TextDisabledLight">#C4A96A</Color>

    <!-- ============================================================
         LEGACY ALIASES
    ============================================================ -->
    <Color x:Key="Primary">#C89020</Color>
    <Color x:Key="PrimaryDark">#E8C060</Color>
    <Color x:Key="PrimaryDarkText">#E8D5A0</Color>
    <Color x:Key="Secondary">#FDF0D0</Color>
    <Color x:Key="SecondaryDarkText">#C89020</Color>
    <Color x:Key="Tertiary">#A87010</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#110E09</Color>
    <Color x:Key="Magenta">#C89020</Color>
    <Color x:Key="MidnightBlue">#110E09</Color>

    <Color x:Key="Gray100">#F5EDD8</Color>
    <Color x:Key="Gray200">#EDE0C4</Color>
    <Color x:Key="Gray300">#E3D4B0</Color>
    <Color x:Key="Gray400">#C4A96A</Color>
    <Color x:Key="Gray500">#A09070</Color>
    <Color x:Key="Gray600">#6B5A3A</Color>
    <Color x:Key="Gray900">#22190F</Color>
    <Color x:Key="Gray950">#110E09</Color>

    <!-- Neutral scale (kept for disabled button states) -->
    <Color x:Key="Neutral200">#E3D4B0</Color>
    <Color x:Key="Neutral700">#22190F</Color>
    <Color x:Key="Neutral800">#1A1510</Color>

    <!-- ============================================================
         BRUSHES
    ============================================================ -->
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimary}" />
    <SolidColorBrush x:Key="StatusHealthyBrush" Color="{StaticResource StatusHealthy}" />
    <SolidColorBrush x:Key="StatusDegradedBrush" Color="{StaticResource StatusDegraded}" />
    <SolidColorBrush x:Key="StatusUnhealthyBrush" Color="{StaticResource StatusUnhealthy}" />
    <SolidColorBrush x:Key="StatusUnknownBrush" Color="{StaticResource StatusUnknown}" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource BrandPrimary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />

    <!-- ============================================================
         SPACING TOKENS (x:Double)
    ============================================================ -->
    <x:Double x:Key="SpacingXS">4</x:Double>
    <x:Double x:Key="SpacingS">8</x:Double>
    <x:Double x:Key="SpacingM">16</x:Double>
    <x:Double x:Key="SpacingL">24</x:Double>
    <x:Double x:Key="SpacingXL">32</x:Double>
    <x:Double x:Key="SpacingXXL">48</x:Double>

    <!-- ============================================================
         CORNER RADIUS TOKENS
    ============================================================ -->
    <x:Double x:Key="RadiusXS">4</x:Double>
    <x:Double x:Key="RadiusS">6</x:Double>
    <x:Double x:Key="RadiusM">8</x:Double>
    <x:Double x:Key="RadiusL">12</x:Double>
    <x:Double x:Key="RadiusXL">16</x:Double>

    <!-- ============================================================
         TYPOGRAPHY SCALE (x:Double)
    ============================================================ -->
    <x:Double x:Key="FontSizeCaption">11</x:Double>
    <x:Double x:Key="FontSizeBody">13</x:Double>
    <x:Double x:Key="FontSizeBodyLarge">15</x:Double>
    <x:Double x:Key="FontSizeTitle">17</x:Double>
    <x:Double x:Key="FontSizeHeadline">22</x:Double>
    <x:Double x:Key="FontSizeDisplay">28</x:Double>

</ResourceDictionary>
