<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:HCApp.Converters"
             x:Class="HCApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:StatusToColorConverter x:Key="StatusToColor" />
            <converters:StatusToBackgroundConverter x:Key="StatusToBackground" />
            <converters:StatusToGlowConverter x:Key="StatusToGlow" />
            <converters:BoolToOpacityConverter x:Key="LampOpacity" TrueOpacity="1.0" FalseOpacity="0.4" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
