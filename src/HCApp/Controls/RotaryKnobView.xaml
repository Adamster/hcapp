<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HCApp.Controls.RotaryKnobView">

    <AbsoluteLayout WidthRequest="220" HeightRequest="220">

        <GraphicsView x:Name="KnobCanvas"
                      AbsoluteLayout.LayoutBounds="0,0,220,220"
                      AbsoluteLayout.LayoutFlags="None" />

        <Border x:Name="Nameplate"
                AbsoluteLayout.LayoutBounds="20,168,180,34"
                AbsoluteLayout.LayoutFlags="None"
                BackgroundColor="#1A2030"
                Stroke="#4A3C28"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 4"
                Padding="8,4"
                IsVisible="False">
            <Label x:Name="NameplateLabel"
                   FontFamily="Courier New"
                   FontSize="11"
                   FontAttributes="Bold"
                   CharacterSpacing="0.8"
                   TextColor="#C89020"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   LineBreakMode="TailTruncation"
                   HorizontalOptions="Fill" />
        </Border>

    </AbsoluteLayout>

</ContentView>
