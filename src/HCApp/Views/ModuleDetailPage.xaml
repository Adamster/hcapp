<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HCApp.ViewModels"
             xmlns:models="clr-namespace:HCApp.Models"
             x:Class="HCApp.Views.ModuleDetailPage"
             x:DataType="vm:ModuleDetailViewModel"
             Title="{Binding Module.Name}">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto">

        <!-- Module status header card -->
        <Border Grid.Row="0"
                Stroke="Transparent"
                StrokeThickness="0"
                BackgroundColor="{Binding Status, Converter={StaticResource StatusToBackground}}"
                Padding="24,16">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="32" RowDefinitions="Auto,Auto" RowSpacing="8">

                <!-- Status + name -->
                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Ellipse WidthRequest="14" HeightRequest="14"
                             Fill="{Binding Status, Converter={StaticResource StatusToColor}}"
                             VerticalOptions="Center" />
                    <Label Text="{Binding StatusText}"
                           Style="{StaticResource HeadlineLabel}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Duration -->
                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="DURATION"
                           Style="{StaticResource CaptionLabel}"
                           FontFamily="OpenSansSemiBold"
                           CharacterSpacing="0.6" />
                    <Label Text="{Binding TotalDuration}"
                           Style="{StaticResource TitleLabel}" />
                </VerticalStackLayout>

                <!-- Last checked -->
                <VerticalStackLayout Grid.Row="0" Grid.Column="2" Spacing="2" VerticalOptions="Center">
                    <Label Text="LAST CHECKED"
                           Style="{StaticResource CaptionLabel}"
                           FontFamily="OpenSansSemiBold"
                           CharacterSpacing="0.6" />
                    <Label Text="{Binding LastChecked}"
                           Style="{StaticResource TitleLabel}" />
                </VerticalStackLayout>

                <!-- Environment -->
                <VerticalStackLayout Grid.Row="0" Grid.Column="3" Spacing="2" VerticalOptions="Center">
                    <Label Text="ENVIRONMENT"
                           Style="{StaticResource CaptionLabel}"
                           FontFamily="OpenSansSemiBold"
                           CharacterSpacing="0.6" />
                    <Label Text="{Binding EnvironmentName}"
                           Style="{StaticResource TitleLabel}" />
                </VerticalStackLayout>

                <!-- Error message, spans full width -->
                <Border Grid.Row="1" Grid.ColumnSpan="4"
                        StrokeShape="RoundRectangle 6"
                        StrokeThickness="1"
                        Stroke="{StaticResource StatusUnhealthyDim}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource StatusUnhealthySubtleLight}, Dark={StaticResource StatusUnhealthySubtle}}"
                        Padding="12,8"
                        IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Error:"
                               Style="{StaticResource BodyLabel}"
                               FontFamily="OpenSansSemiBold"
                               TextColor="{StaticResource StatusUnhealthy}"
                               VerticalOptions="Center" />
                        <Label Text="{Binding Error}"
                               Style="{StaticResource BodyLabel}"
                               TextColor="{StaticResource StatusUnhealthy}"
                               LineBreakMode="WordWrap"
                               VerticalOptions="Center"
                               HorizontalOptions="Fill" />
                    </HorizontalStackLayout>
                </Border>

            </Grid>
        </Border>

        <!-- Bottom border for header -->
        <BoxView Grid.Row="0"
                 HeightRequest="1"
                 Opacity="0.6"
                 VerticalOptions="End" />

        <!-- Entries section header -->
        <Border Grid.Row="1"
                Style="{StaticResource SectionHeaderBorder}">
            <Label Text="Health Check Entries"
                   Style="{StaticResource TitleLabel}" />
        </Border>

        <!-- Entries list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Entries}">

            <CollectionView.EmptyView>
                <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="48" RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Label Grid.Row="0"
                           Text="No detailed entries"
                           Style="{StaticResource TitleLabel}"
                           HorizontalTextAlignment="Center" />
                    <Label Grid.Row="1"
                           Text="This health check did not return any entry-level details."
                           Style="{StaticResource SecondaryLabel}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.Header>
                <Border Stroke="Transparent"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondaryLight}, Dark={StaticResource SurfaceSecondaryDark}}"
                        Padding="24,8">
                    <Grid ColumnDefinitions="20,*,160" ColumnSpacing="12">
                        <Label Grid.Column="1"
                               Text="ENTRY"
                               Style="{StaticResource CaptionLabel}"
                               FontFamily="OpenSansSemiBold"
                               CharacterSpacing="0.8" />
                        <Label Grid.Column="2"
                               Text="DURATION"
                               Style="{StaticResource CaptionLabel}"
                               FontFamily="OpenSansSemiBold"
                               CharacterSpacing="0.8"
                               HorizontalTextAlignment="End" />
                    </Grid>
                </Border>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:EntryViewModel">
                    <Grid Padding="0">
                        <Border Stroke="Transparent"
                                StrokeThickness="0"
                                StrokeShape="Rectangle"
                                BackgroundColor="Transparent"
                                Padding="24,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="{x:Static models:HealthStatus.Unhealthy}">
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource StatusUnhealthySubtleLight}, Dark={StaticResource StatusUnhealthySubtle}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="{x:Static models:HealthStatus.Degraded}">
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource StatusDegradedSubtleLight}, Dark={StaticResource StatusDegradedSubtle}}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid ColumnDefinitions="20,*,160" ColumnSpacing="12" Padding="0,10">
                                <!-- Status dot -->
                                <Ellipse Grid.Column="0"
                                         WidthRequest="8" HeightRequest="8"
                                         Fill="{Binding Status, Converter={StaticResource StatusToColor}}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center" />

                                <!-- Name + description -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           Style="{StaticResource BodyLargeLabel}"
                                           FontFamily="OpenSansSemiBold"
                                           HorizontalOptions="Fill" />
                                    <Label Text="{Binding Description}"
                                           Style="{StaticResource SecondaryLabel}"
                                           LineBreakMode="WordWrap"
                                           HorizontalOptions="Fill"
                                           IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}" />
                                </VerticalStackLayout>

                                <!-- Duration -->
                                <Label Grid.Column="2"
                                       Text="{Binding Duration}"
                                       Style="{StaticResource SecondaryLabel}"
                                       HorizontalTextAlignment="End"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!-- Row separator -->
                        <BoxView HeightRequest="1"
                                 Opacity="0.5"
                                 VerticalOptions="End"
                                 HorizontalOptions="Fill"
                                 Margin="24,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- History section header -->
        <Border Grid.Row="3"
                Style="{StaticResource SectionHeaderBorder}">
            <Label Text="Recent Status History"
                   Style="{StaticResource TitleLabel}" />
        </Border>

        <!-- History items — horizontal scrollable strip -->
        <ScrollView Grid.Row="4" Orientation="Horizontal" Padding="24,12">
            <HorizontalStackLayout Spacing="8"
                                   BindableLayout.ItemsSource="{Binding History}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:StatusHistoryEntry">
                        <Border Style="{StaticResource CardBorder}"
                                Padding="12,8"
                                MinimumWidthRequest="120">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Ellipse WidthRequest="8" HeightRequest="8"
                                         Fill="{Binding Status, Converter={StaticResource StatusToColor}}"
                                         HorizontalOptions="Center" />
                                <Label Text="{Binding Status}"
                                       Style="{StaticResource BodyLabel}"
                                       FontFamily="OpenSansSemiBold"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss}'}"
                                       Style="{StaticResource CaptionLabel}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Footer separator -->
        <BoxView Grid.Row="5"
                 HeightRequest="1"
                 BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceBorderLight}, Dark={StaticResource SurfaceBorderDark}}" />

        <!-- Footer back button -->
        <Border Grid.Row="6"
                StrokeShape="Rectangle"
                StrokeThickness="0"
                Stroke="Transparent"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondaryLight}, Dark={StaticResource SurfaceSecondaryDark}}"
                Padding="24,12">
            <Button Text="← Back"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding GoBackCommand}"
                    HorizontalOptions="Start" />
        </Border>

    </Grid>
</ContentPage>
