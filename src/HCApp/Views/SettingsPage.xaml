<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HCApp.ViewModels"
             x:Class="HCApp.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <Grid RowDefinitions="*,Auto,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20" Padding="32,28">

                <Label Text="Notifications"
                       Style="{StaticResource TitleLabel}"
                       Margin="0,0,0,4" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                        <Label Text="Enable Notifications" Style="{StaticResource BodyLargeLabel}" FontFamily="OpenSansSemiBold" />
                        <Label Text="Send a native OS notification when a module changes status." Style="{StaticResource CaptionLabel}" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding NotificationsEnabled}"
                            VerticalOptions="Center" />
                </Grid>

                <Label Text="Polling"
                       Style="{StaticResource TitleLabel}"
                       Margin="0,12,0,4" />

                <VerticalStackLayout Spacing="6">
                    <Label Text="Default Polling Interval (seconds)" Style="{StaticResource FieldLabelStyle}" />
                    <Border Style="{StaticResource InputFieldBorder}"
                            MaximumWidthRequest="160"
                            HorizontalOptions="Start">
                        <Entry Text="{Binding DefaultPollingInterval}"
                               Keyboard="Numeric"
                               ReturnType="Done" />
                    </Border>
                    <Label Text="Applied to new environments. Existing environments keep their own interval."
                           Style="{StaticResource CaptionLabel}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceBorderLight}, Dark={StaticResource SurfaceBorderDark}}" />

        <Border Grid.Row="2"
                StrokeShape="Rectangle"
                StrokeThickness="0"
                Stroke="Transparent"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondaryLight}, Dark={StaticResource SurfaceSecondaryDark}}"
                Padding="32,12">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <BoxView Grid.Column="0" BackgroundColor="Transparent" />
                <Button Grid.Column="1"
                        Text="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}"
                        MinimumWidthRequest="88" />
                <Button Grid.Column="2"
                        Text="Save"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"
                        MinimumWidthRequest="88" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
