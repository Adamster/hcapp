<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HCApp.ViewModels"
             xmlns:models="clr-namespace:HCApp.Models"
             xmlns:controls="clr-namespace:HCApp.Controls"
             x:Class="HCApp.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Health Monitor">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource ToolbarBorder}">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8"  RowDefinitions="Auto" VerticalOptions="Center">

                <!-- Environment selector -->
                <Border Grid.Column="0"
                        BackgroundColor="#1A1510"
                        Stroke="#4A3C28"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 3"
                        Padding="4,2"
                        MinimumWidthRequest="160"
                        VerticalOptions="Center">
                    <Picker ItemsSource="{Binding Environments}"
                            SelectedItem="{Binding SelectedEnvironment}"
                            ItemDisplayBinding="{Binding Name}"
                            TextColor="#E8D5A0"
                            FontFamily="Courier New"
                            FontSize="12"
                            BackgroundColor="Transparent"
                            TitleColor="#7A6240"
                            Title="Select environment" />
                </Border>

                <!-- Add environment -->
                <controls:SteampunkButton Grid.Column="1"
                        Text="New"
                        VerticalOptions="Center"
                        Variant="Secondary"
                        Command="{Binding AddEnvironmentCommand}"
                        ToolTipProperties.Text="Add environment" />

                <!-- Edit environment -->
                <controls:SteampunkButton Grid.Column="2"
                        Text="Edit"
                        VerticalOptions="Center"
                        Variant="Secondary"
                        Command="{Binding EditEnvironmentCommand}"
                        ToolTipProperties.Text="Edit selected environment" />

                <!-- Clone environment -->
                <controls:SteampunkButton Grid.Column="3"
                        Text="Clone"
                        Variant="Secondary"
                        VerticalOptions="Center"
                        Command="{Binding CloneEnvironmentCommand}"
                        ToolTipProperties.Text="Clone selected environment" />

                <!-- Delete environment -->
                <controls:SteampunkButton Grid.Column="4"
                        Text="Delete"
                        Variant="Danger"
                        VerticalOptions="Center"
                        Command="{Binding DeleteEnvironmentCommand}"
                        ToolTipProperties.Text="Delete selected environment" />

                <!-- Spacer -->
                <BoxView Grid.Column="5" BackgroundColor="Transparent" />

                <!-- Export config -->
                <controls:SteampunkButton Grid.Column="6"
                        Text="Export"
                        Variant="Secondary"
                        VerticalOptions="Center"
                        Command="{Binding ExportConfigCommand}"
                        ToolTipProperties.Text="Export configuration to JSON file" />

                <!-- Import config -->
                <controls:SteampunkButton Grid.Column="7"
                        Text="Import"
                        Variant="Secondary"
                        VerticalOptions="Center"
                        Command="{Binding ImportConfigCommand}"
                        ToolTipProperties.Text="Import configuration from JSON file" />

                <!-- Refresh all -->
                <controls:SteampunkButton Grid.Column="8"
                        Text="Refresh"
                        Variant="Secondary"
                        VerticalOptions="Center"
                        Command="{Binding RefreshAllCommand}"
                        ToolTipProperties.Text="Check all modules now" />

                <!-- Add module -->
                <controls:SteampunkButton Grid.Column="9"
                        Text="+ Add Module"
                        Variant="Primary"
                        VerticalOptions="Center"
                        Command="{Binding AddModuleCommand}" />

                <!-- Settings -->
                <controls:SteampunkButton Grid.Column="10"
                        Text="⚙"
                        Variant="Secondary"
                        VerticalOptions="Center"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTipProperties.Text="Settings"
                        MinimumWidthRequest="40" />
            </Grid>
        </Border>

        <!-- Toolbar bottom separator — brass seam -->
        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 BackgroundColor="#4A3C28" />

        <!-- Environment status bar (retro analog panel) — DO NOT MODIFY -->
        <Grid Grid.Row="2" RowDefinitions="2,1,*,1" BackgroundColor="#1A2030">
            <!-- Ridge top highlight -->
            <BoxView Grid.Row="0" BackgroundColor="#2A3A55" HeightRequest="2" VerticalOptions="Fill" />
            <!-- Ridge shadow undercut -->
            <BoxView Grid.Row="1" BackgroundColor="#0A0F18" HeightRequest="1" VerticalOptions="Fill" />

            <!-- Lamps scroll area -->
            <ScrollView Grid.Row="2" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Padding="16,8">
                <HorizontalStackLayout Spacing="24"
                                       VerticalOptions="Center"
                                       BindableLayout.ItemsSource="{Binding EnvironmentStatuses}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:EnvironmentStatusViewModel">
                            <VerticalStackLayout Spacing="4"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                MinimumWidthRequest="52"
                                                Opacity="{Binding IsSelected, Converter={StaticResource LampOpacity}}">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=SelectEnvironmentCommand}"
                                        CommandParameter="{Binding .}" />
                                </VerticalStackLayout.GestureRecognizers>

                                <!-- Lamp assembly: selection ring + socket + bulb -->
                                <Grid HorizontalOptions="Center"
                                      WidthRequest="28"
                                      HeightRequest="28">

                                    <!-- Selection ring (only visible when selected) -->
                                    <Ellipse WidthRequest="28" HeightRequest="28"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Fill="Transparent"
                                             Stroke="{Binding OverallStatus, Converter={StaticResource StatusToColor}}"
                                             StrokeThickness="1.5"
                                             Opacity="0.65"
                                             IsVisible="{Binding IsSelected}" />

                                    <!-- Socket bezel (dark ring) -->
                                    <Ellipse WidthRequest="22" HeightRequest="22"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Fill="#0D1018" />

                                    <!-- Bulb fill with glow shadow -->
                                    <Border WidthRequest="18"
                                            HeightRequest="18"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            BackgroundColor="{Binding OverallStatus, Converter={StaticResource StatusToColor}}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 9"
                                            Shadow="{Binding OverallStatus, Converter={StaticResource StatusToGlow}}">
                                        <!-- Glass sheen highlight -->
                                        <Grid>
                                            <Ellipse WidthRequest="6"
                                                     HeightRequest="6"
                                                     Fill="White"
                                                     Opacity="0.18"
                                                     HorizontalOptions="Start"
                                                     VerticalOptions="Start"
                                                     Margin="2,2,0,0" />
                                        </Grid>
                                    </Border>

                                </Grid>

                                <!-- Hardware label -->
                                <Label Text="{Binding Name}"
                                       FontSize="9"
                                       FontFamily="Courier New"
                                       CharacterSpacing="0.8"
                                       HorizontalTextAlignment="Center"
                                       HorizontalOptions="Center"
                                       TextColor="#8090B0">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="TextColor" Value="#C8D8F0" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Bottom seam -->
            <BoxView Grid.Row="3" BackgroundColor="#0A0F18" HeightRequest="1" VerticalOptions="Fill" />
        </Grid>

        <!-- Status bar bottom separator — brass seam -->
        <BoxView Grid.Row="3"
                 HeightRequest="1"
                 BackgroundColor="#4A3C28" />

        <!-- Content area -->
        <Grid Grid.Row="4" RowDefinitions="*">

            <!-- Module list -->
            <CollectionView ItemsSource="{Binding Modules}"
                            SelectionMode="Single"
                            SelectionChangedCommand="{Binding ViewModuleDetailCommand}"
                            SelectionChangedCommandParameter="{Binding Source={RelativeSource Self}, Path=SelectedItem}"
                            Margin="0">

                <CollectionView.EmptyView>
                    <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="48" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                        <Label Grid.Row="0"
                               Text="No modules configured"
                               Style="{StaticResource TitleLabel}"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="1"
                               Text="Select an environment and add a module to begin monitoring."
                               Style="{StaticResource SecondaryLabel}"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                        <controls:SteampunkButton Grid.Row="2"
                                Text="+ Add Module"
                                Variant="Primary"
                                Command="{Binding AddModuleCommand}"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0" />
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.Header>
                    <!-- Column header row — stamped metal plaque style -->
                    <Border Stroke="{AppThemeBinding Light={StaticResource SurfaceBorderLight}, Dark={StaticResource SurfaceBorderDark}}"
                            StrokeThickness="1"
                            StrokeShape="Rectangle"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondaryLight}, Dark={StaticResource SurfaceSecondaryDark}}"
                            Padding="20,8">
                        <Grid ColumnDefinitions="24,*,140,140,48" ColumnSpacing="12">
                            <Label Grid.Column="1"
                                   Text="MODULE"
                                   Style="{StaticResource CaptionLabel}"
                                   FontFamily="Courier New"
                                   CharacterSpacing="1.2"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="DURATION"
                                   Style="{StaticResource CaptionLabel}"
                                   FontFamily="Courier New"
                                   CharacterSpacing="1.2"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3"
                                   Text="LAST CHECKED"
                                   Style="{StaticResource CaptionLabel}"
                                   FontFamily="Courier New"
                                   CharacterSpacing="1.2"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ModuleStatusViewModel">
                        <Grid Padding="0">
                            <!-- Row background + hover affordance -->
                            <Border Stroke="Transparent"
                                    StrokeThickness="0"
                                    StrokeShape="Rectangle"
                                    BackgroundColor="Transparent"
                                    Padding="20,0">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="{x:Static models:HealthStatus.Unhealthy}">
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light={StaticResource StatusUnhealthySubtleLight}, Dark={StaticResource StatusUnhealthySubtle}}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid ColumnDefinitions="24,*,140,140,48" ColumnSpacing="12" Padding="0,12">

                                    <!-- Status dot -->
                                    <Ellipse Grid.Column="0"
                                             WidthRequest="10" HeightRequest="10"
                                             Fill="{Binding Status, Converter={StaticResource StatusToColor}}"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center" />

                                    <!-- Module name + URL + error badge -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource BodyLargeLabel}"
                                               FontFamily="OpenSansSemiBold"
                                               HorizontalOptions="Fill" />
                                        <Label Text="{Binding FullUrl}"
                                               Style="{StaticResource CaptionLabel}"
                                               FontFamily="Courier New"
                                               CharacterSpacing="0.4"
                                               LineBreakMode="TailTruncation"
                                               HorizontalOptions="Fill" />
                                        <Label Text="{Binding Error}"
                                               Style="{StaticResource CaptionLabel}"
                                               TextColor="{StaticResource StatusUnhealthy}"
                                               LineBreakMode="TailTruncation"
                                               HorizontalOptions="Fill"
                                               IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />
                                    </VerticalStackLayout>

                                    <!-- Duration — instrument readout -->
                                    <Label Grid.Column="2"
                                           Text="{Binding Duration}"
                                           Style="{StaticResource SecondaryLabel}"
                                           FontFamily="Courier New"
                                           HorizontalTextAlignment="End"
                                           VerticalOptions="Center" />

                                    <!-- Last checked — instrument readout -->
                                    <Label Grid.Column="3"
                                           Text="{Binding LastChecked}"
                                           Style="{StaticResource SecondaryLabel}"
                                           FontFamily="Courier New"
                                           HorizontalTextAlignment="End"
                                           VerticalOptions="Center" />

                                    <!-- Per-module refresh -->
                                    <controls:SteampunkButton Grid.Column="4"
                                            Text="↻"
                                            Variant="Icon"
                                            MinimumWidthRequest="36"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=RefreshModuleCommand}"
                                            CommandParameter="{Binding .}"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center"
                                            ToolTipProperties.Text="Check now" />
                                </Grid>
                            </Border>

                            <!-- Row separator — aged brass -->
                            <BoxView HeightRequest="1"
                                     BackgroundColor="#4A3C28"
                                     Opacity="0.6"
                                     VerticalOptions="End"
                                     HorizontalOptions="Fill"
                                     Margin="20,0" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Loading overlay -->
            <Grid IsVisible="{Binding IsLoading}"
                  BackgroundColor="{AppThemeBinding Light=#80F5EDD8, Dark=#80110E09}"
                  ZIndex="10">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   WidthRequest="32"
                                   HeightRequest="32" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
