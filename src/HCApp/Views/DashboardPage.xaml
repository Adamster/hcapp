<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HCApp.ViewModels"
             xmlns:models="clr-namespace:HCApp.Models"
             x:Class="HCApp.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Health Monitor">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource ToolbarBorder}">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="8" RowDefinitions="Auto">

                <!-- Environment picker -->
                <Border Grid.Column="0" Style="{StaticResource PickerFieldBorder}">
                    <Picker Title="Select environment"
                            ItemsSource="{Binding Environments}"
                            SelectedItem="{Binding SelectedEnvironment}"
                            ItemDisplayBinding="{Binding Name}"
                            MinimumWidthRequest="220" />
                </Border>

                <!-- Add environment -->
                <Button Grid.Column="1"
                        Text="New"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding AddEnvironmentCommand}"
                        ToolTipProperties.Text="Add environment" />

                <!-- Edit environment -->
                <Button Grid.Column="2"
                        Text="Edit"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding EditEnvironmentCommand}"
                        ToolTipProperties.Text="Edit selected environment" />

                <!-- Delete environment -->
                <Button Grid.Column="3"
                        Text="Delete"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteEnvironmentCommand}"
                        ToolTipProperties.Text="Delete selected environment" />

                <!-- Spacer -->
                <BoxView Grid.Column="4" BackgroundColor="Transparent" />

                <!-- Refresh all -->
                <Button Grid.Column="5"
                        Text="Refresh"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshAllCommand}"
                        ToolTipProperties.Text="Check all modules now" />

                <!-- Add module -->
                <Button Grid.Column="6"
                        Text="+ Add Module"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddModuleCommand}" />
            </Grid>
        </Border>

        <!-- Toolbar bottom separator -->
        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceBorderLight}, Dark={StaticResource SurfaceBorderDark}}" />

        <!-- Content area -->
        <Grid Grid.Row="2" RowDefinitions="*">

            <!-- Module list -->
            <CollectionView ItemsSource="{Binding Modules}"
                            SelectionMode="Single"
                            SelectionChangedCommand="{Binding ViewModuleDetailCommand}"
                            SelectionChangedCommandParameter="{Binding Source={RelativeSource Self}, Path=SelectedItem}"
                            Margin="0">

                <CollectionView.EmptyView>
                    <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="48" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                        <Label Grid.Row="0"
                               Text="No modules configured"
                               Style="{StaticResource TitleLabel}"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="1"
                               Text="Select an environment and add a module to begin monitoring."
                               Style="{StaticResource SecondaryLabel}"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                        <Button Grid.Row="2"
                                Text="+ Add Module"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddModuleCommand}"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0" />
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.Header>
                    <!-- Column header row -->
                    <Border Stroke="Transparent"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondaryLight}, Dark={StaticResource SurfaceSecondaryDark}}"
                            Padding="20,8">
                        <Grid ColumnDefinitions="24,*,140,140,48" ColumnSpacing="12">
                            <Label Grid.Column="1"
                                   Text="MODULE"
                                   Style="{StaticResource CaptionLabel}"
                                   FontFamily="OpenSansSemiBold"
                                   CharacterSpacing="0.8"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="DURATION"
                                   Style="{StaticResource CaptionLabel}"
                                   FontFamily="OpenSansSemiBold"
                                   CharacterSpacing="0.8"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3"
                                   Text="LAST CHECKED"
                                   Style="{StaticResource CaptionLabel}"
                                   FontFamily="OpenSansSemiBold"
                                   CharacterSpacing="0.8"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ModuleStatusViewModel">
                        <Grid Padding="0">
                            <!-- Row background + hover affordance -->
                            <Border Stroke="Transparent"
                                    StrokeThickness="0"
                                    StrokeShape="Rectangle"
                                    BackgroundColor="Transparent"
                                    Padding="20,0">
                                <!-- Bottom border separator -->
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="{x:Static models:HealthStatus.Unhealthy}">
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light={StaticResource StatusUnhealthySubtleLight}, Dark={StaticResource StatusUnhealthySubtle}}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid ColumnDefinitions="24,*,140,140,48" ColumnSpacing="12" Padding="0,12">

                                    <!-- Status dot -->
                                    <Ellipse Grid.Column="0"
                                             WidthRequest="10" HeightRequest="10"
                                             Fill="{Binding Status, Converter={StaticResource StatusToColor}}"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center" />

                                    <!-- Module name + URL + error badge -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource BodyLargeLabel}"
                                               FontFamily="OpenSansSemiBold"
                                               HorizontalOptions="Fill" />
                                        <Label Text="{Binding FullUrl}"
                                               Style="{StaticResource CaptionLabel}"
                                               LineBreakMode="TailTruncation"
                                               HorizontalOptions="Fill" />
                                        <Label Text="{Binding Error}"
                                               Style="{StaticResource CaptionLabel}"
                                               TextColor="{StaticResource StatusUnhealthy}"
                                               LineBreakMode="TailTruncation"
                                               HorizontalOptions="Fill"
                                               IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />
                                    </VerticalStackLayout>

                                    <!-- Duration -->
                                    <Label Grid.Column="2"
                                           Text="{Binding Duration}"
                                           Style="{StaticResource SecondaryLabel}"
                                           FontFamily="OpenSansRegular"
                                           HorizontalTextAlignment="End"
                                           VerticalOptions="Center" />

                                    <!-- Last checked -->
                                    <Label Grid.Column="3"
                                           Text="{Binding LastChecked}"
                                           Style="{StaticResource SecondaryLabel}"
                                           HorizontalTextAlignment="End"
                                           VerticalOptions="Center" />

                                    <!-- Per-module refresh -->
                                    <Button Grid.Column="4"
                                            Text="↻"
                                            FontSize="16"
                                            Padding="4"
                                            MinimumWidthRequest="36"
                                            MinimumHeightRequest="36"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=RefreshModuleCommand}"
                                            CommandParameter="{Binding .}"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center"
                                            ToolTipProperties.Text="Check now" />
                                </Grid>
                            </Border>

                            <!-- Row separator -->
                            <BoxView HeightRequest="1"
                                     Opacity="0.5"
                                     VerticalOptions="End"
                                     HorizontalOptions="Fill"
                                     Margin="20,0" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Loading overlay -->
            <Grid IsVisible="{Binding IsLoading}"
                  BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#800E1117}"
                  ZIndex="10">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   WidthRequest="32"
                                   HeightRequest="32" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
